generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  budgetYears BudgetYear[]
  categories  Category[]

  @@map("users")
}

model BudgetYear {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  year             Int
  createdAt        DateTime @default(now()) @map("created_at")
  copiedFromYearId String?  @map("copied_from_year_id")

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses     Expense[]
  incomes      Income[]
  transactions Transaction[]

  @@unique([userId, year])
  @@map("budget_years")
}

model Category {
  id        String  @id @default(uuid())
  userId    String  @map("user_id")
  name      String
  color     String  @default("#6366f1")
  icon      String  @default("tag")
  parentId  String? @map("parent_id")
  sortOrder Int     @default(0) @map("sort_order")

  user     User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  expenses Expense[]

  @@map("categories")
}

model Expense {
  id               String      @id @default(uuid())
  yearId           String      @map("year_id")
  categoryId       String?     @map("category_id")
  name             String
  amount           Decimal     @db.Decimal(12, 2)
  frequency        Frequency
  type             ExpenseType
  notes            String?
  discountPct      Int         @default(0) @map("discount_pct")
  factor           Decimal     @default(1) @db.Decimal(5, 2) @map("factor")
  monthSplitFrom    Int?        @map("month_split_from")
  monthSplitAmount  Decimal?    @db.Decimal(12, 2) @map("month_split_amount")
  monthSplitFactor  Decimal?    @db.Decimal(5, 2) @map("month_split_factor")
  sortOrder         Int         @default(0) @map("sort_order")
  createdAt         DateTime    @default(now()) @map("created_at")

  year         BudgetYear    @relation(fields: [yearId], references: [id], onDelete: Cascade)
  category     Category?     @relation(fields: [categoryId], references: [id])
  transactions Transaction[]

  @@map("expenses")
}

model Income {
  id               String     @id @default(uuid())
  yearId           String     @map("year_id")
  name             String
  amount100Pct     Decimal    @db.Decimal(12, 2) @map("amount_100pct")
  employmentPct    Int        @default(100) @map("employment_pct")
  factor           Decimal    @default(1) @db.Decimal(5, 2) @map("factor")
  monthSplitFrom          Int?       @map("month_split_from")
  monthSplitAmount        Decimal?   @db.Decimal(12, 2) @map("month_split_amount")
  monthSplitFactor        Decimal?   @db.Decimal(5, 2) @map("month_split_factor")
  monthSplitEmploymentPct Int?       @map("month_split_employment_pct")
  frequency               Frequency
  type             IncomeType
  notes            String?
  sortOrder        Int        @default(0) @map("sort_order")
  createdAt        DateTime   @default(now()) @map("created_at")

  year BudgetYear @relation(fields: [yearId], references: [id], onDelete: Cascade)

  @@map("incomes")
}

model Transaction {
  id                String   @id @default(uuid())
  yearId            String   @map("year_id")
  date              DateTime @db.Date
  description       String
  amount            Decimal  @db.Decimal(12, 2)
  matchedExpenseId  String?  @map("matched_expense_id")
  aiCategory        String?  @map("ai_category")
  aiConfidence      Float?   @map("ai_confidence")
  isIncome          Boolean  @default(false) @map("is_income")
  createdAt         DateTime @default(now()) @map("created_at")

  year           BudgetYear @relation(fields: [yearId], references: [id], onDelete: Cascade)
  matchedExpense Expense?   @relation(fields: [matchedExpenseId], references: [id])

  @@map("transactions")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  action    String
  details   String?
  ip        String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
  @@index([userId])
  @@index([createdAt])
}

enum Frequency {
  monthly
  yearly
  once
}

enum ExpenseType {
  fixed
  estimate
  savings
}

enum IncomeType {
  salary
  other
}
