# ============================================
# Finanzplan — Environment Variables
# ============================================

# Supabase (Authentifizierung + Datenbank)
NEXT_PUBLIC_SUPABASE_URL=https://DEIN_PROJEKT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...  # Für Account-Löschung

# Prisma (PostgreSQL)
DATABASE_URL=postgresql://postgres:PASSWORD@db.DEIN_PROJEKT.supabase.co:5432/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:PASSWORD@db.DEIN_PROJEKT.supabase.co:5432/postgres

# Rate Limiting mit Upstash Redis (optional, aber empfohlen für Produktion)
# Kostenlos auf https://upstash.com
UPSTASH_REDIS_REST_URL=https://YOUR_ID.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# Anthropic Claude API (optional - nur für PDF-Analyse)
# ANTHROPIC_API_KEY=sk-ant-...
